%% ─── Verification & Validation ──────────────────────────────────────────────

@book{oberkampf2010,
  author    = {Oberkampf, William L. and Roy, Christopher J.},
  title     = {Verification and Validation in Scientific Computing},
  publisher = {Cambridge University Press},
  year      = {2010},
  isbn      = {978-0-521-11360-1},
  note      = {Comprehensive V\&V framework. Key contributions to CCCS:
               distinction between verification (``solving the equations right'')
               and validation (``solving the right equations'');
               Method of Manufactured Solutions (MMS) as primary code
               verification technique (Ch.~4--5); Richardson extrapolation
               for order-of-accuracy testing; regression testing against
               reference solutions.},
}


%% ─── Simulation Study Design & Reporting ────────────────────────────────────

@article{morris2019,
  author    = {Morris, Tim P. and White, Ian R. and Crowther, Michael J.},
  title     = {Using Simulation Studies to Evaluate Statistical Methods},
  journal   = {Statistics in Medicine},
  volume    = {38},
  number    = {11},
  pages     = {2074--2102},
  year      = {2019},
  doi       = {10.1002/sim.8086},
  note      = {Introduces ADEMP framework (Aims, Data-generating mechanisms,
               Estimands, Methods, Performance measures) for simulation study
               design and reporting. Key requirements adopted by CCCS:
               mandatory MCSE reporting (\S5); matched seed sequences for
               method comparison (\S4); formula for minimum repetitions based
               on desired MCSE --- for 95\% coverage with SE $<$ 0.5\%,
               $n_{\mathrm{sim}} = 10{,}000$ (\S5.2).},
}


%% ─── Monte Carlo Sample Size Theory ────────────────────────────────────────

@book{fenton2008,
  author    = {Fenton, Gordon A. and Griffiths, D. V.},
  title     = {Risk Assessment in Geotechnical Engineering},
  publisher = {John Wiley \& Sons},
  year      = {2008},
  isbn      = {978-0-470-17820-1},
  note      = {Provides the classic formula for minimum Monte Carlo
               repetitions: $n = (z_{\alpha/2})^2 / (\mathrm{tol}/\sigma)^2$.
               At 95\% confidence with 0.1$\sigma$ error tolerance, $n = 384$.
               Practical recommendations: 500--1{,}000 for second-moment
               analysis; skewness stable after $\sim$15{,}000 samples.},
}


%% ─── LLM Code Generation Quality ───────────────────────────────────────────

@inproceedings{evalplus2023,
  author    = {Liu, Jiawei and Xia, Chunqiu Steven and Wang, Yuyao and Zhang, Lingming},
  title     = {Is Your Code Generated by {ChatGPT} Really Correct?
               Rigorous Evaluation of Large Language Models for Code Generation},
  booktitle = {Advances in Neural Information Processing Systems (NeurIPS)},
  year      = {2023},
  eprint    = {2305.01210},
  archiveprefix = {arXiv},
  note      = {Extended HumanEval test cases by 80$\times$ to build HumanEval+.
               Revealed 19.3--28.9\% additional incorrect code that passed
               original weak tests. Seven categories of non-syntactic
               mistakes identified --- silent errors producing incorrect output
               with no warnings. As LLMs scale, syntactic errors decrease but
               non-syntactic errors persist.},
  url       = {https://arxiv.org/abs/2305.01210},
}


