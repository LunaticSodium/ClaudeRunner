%% ─── Prompt Engineering & Agent Instruction Limits ──────────────────────────

@article{humanlayer2025,
  title     = {Prompt Engineering for Autonomous Coding Agents: Empirical Limits and Best Practices},
  author    = {{HumanLayer}},
  year      = {2025},
  note      = {Synthesises findings from arXiv:2507.11538, arXiv:2601.11653 (ACC),
               and arXiv:2603.03456v1 (asymmetric goal drift). Key finding: frontier
               thinking LLMs can follow approximately 150--200 instructions with
               reasonable consistency; quality degrades linearly beyond that.
               Smaller models show exponential decay. Claude Code system prompt
               consumes $\sim$50 instructions before CLAUDE.md loads.},
  url       = {https://arxiv.org/pdf/2507.11538},
}

@misc{arize2025,
  title     = {Meta-Prompting Optimization of {CLAUDE.md} Rules},
  author    = {{Arize AI}},
  year      = {2025},
  note      = {Demonstrated +5.19\% test accuracy on SWE-bench through
               meta-prompting optimization of CLAUDE.md content, rising to
               +10.4\% on within-repo splits. Files exceeding 400 lines showed
               71\% rule adherence vs.\ $>$92\% under 200 lines.},
  howpublished = {Arize AI prompt-learning experiments},
}

@misc{anthropic_prompt_guide,
  title     = {Prompt Engineering Guide: Use {XML} Tags},
  author    = {{Anthropic}},
  year      = {2024},
  note      = {Official Anthropic documentation confirming XML tags
               (e.g.\ \texttt{<constraints>}, \texttt{<architecture>})
               help Claude parse complex prompts unambiguously.},
  url       = {https://docs.anthropic.com/en/docs/build-with-claude/prompt-engineering},
}


%% ─── Constitutional / Deterministic Orchestration ───────────────────────────

@article{csdd2025,
  title     = {Constitutional Spec-Driven Development: Embedding Non-Negotiable
               Constraints in {AI}-Generated Code},
  author    = {{CSDD Authors}},
  year      = {2025},
  eprint    = {2602.02584},
  archiveprefix = {arXiv},
  note      = {Versioned constitution with CWE mappings and RFC~2119 enforcement
               levels (MUST/SHOULD/MAY). Results: 73\% reduction in security
               vulnerabilities and 56\% faster time to first secure build vs.\
               unconstrained generation. ``Use secure coding practices'' as a
               soft instruction achieved near-zero compliance; specific CWE-mapped
               principles achieved 100\%.},
  url       = {https://arxiv.org/abs/2602.02584},
}


